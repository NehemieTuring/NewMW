
# =========================================================================
# CONFIGURATION DE DEPLOIEMENT DOCKER COMPOSE — MUTUELLE NEHEMIE
# =========================================================================

# --- 1. CONFIGURATION DE LA BASE DE DONNEES EXISTANTE ---
# Nom ou IP du conteneur MySQL 8.0 qui tourne deja sur votre serveur
DB_HOST=mysql_server
DB_PORT=3306
DB_NAME=mutuellen
DB_USER=uermutuelle
DB_PASSWORD=mutuelle1234
# Indiquez ici le mot de passe root ou utilisateur de votre base de donnees existante
# Nom du reseau Docker externe sur lequel tourne votre conteneur mysql_server
# (Par defaut sur Docker standalone, c'est le reseau 'bridge')
DOCKER_NETWORK=bridge


# --- 2. CONFIGURATION DU BACKEND (SPRING BOOT) ---
SPRING_DATASOURCE_URL=jdbc:mysql://${DB_HOST}:${DB_PORT}/${DB_NAME}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=${DB_USER}
SPRING_DATASOURCE_PASSWORD=${DB_PASSWORD}

# Cle secrete JWT pour signer les tokens (Minimum 512 bits / 64 caracteres)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970


# --- 3. CONFIGURATION DU FRONTEND (NEXT.JS) ---
# L'URL publique par laquelle le navigateur client de l'utilisateur va joindre l'API Backend
# Exemple en local: http://localhost:8070/api
# Exemple en production Nginx avec SSL: https://api.mutuelle.fingou-services/api
#NEXT_PUBLIC_API_URL=http://localhost:8070/api
NEXT_PUBLIC_API_URL=https://api.mutuelle.fingou-services/api
 
